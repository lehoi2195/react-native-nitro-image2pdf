{
  "name": "react-native-nitro-image2pdf",
  "version": "1.0.0",
  "description": "react-native-nitro-image2pdf is a react native package built with Nitro",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "git clean -dfX",
    "release": "semantic-release",
    "build": "npm run typecheck && bob build",
    "codegen": "nitrogen --logLevel=\"debug\" && npm run build && node post-script.js",
    "test": "npx jest",
    "prepublishOnly": "npm run codegen && npm test"
  },
  "keywords": [
    "react-native",
    "react-native-nitro-image2pdf"
  ],
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "cpp",
    "nitro.json",
    "android/build.gradle",
    "android/fix-prefab.gradle",
    "android/gradle.properties",
    "android/CMakeLists.txt",
    "android/proguard-rules.pro",
    "android/src",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "app.plugin.js",
    "*.podspec",
    "README.md",
    "!**/__tests__"
  ],
  "workspaces": [
    "example"
  ],
  "repository": "https://github.com/lehoi2195/react-native-nitro-image2pdf.git",
  "author": "Hoi Le Van (BTS-CRM-SmartSales)",
  "license": "MIT",
  "bugs": "https://github.com/lehoi2195/react-native-nitro-image2pdf/issues",
  "homepage": "https://github.com/lehoi2195/react-native-nitro-image2pdf#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@jamesacarr/eslint-formatter-github-actions": "^0.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/react": "19.2.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "nitrogen": "0.36.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.40.18",
    "react-native-nitro-modules": "0.36.1",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "semantic-release": "^25.0.3",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.76.0",
    "react-native-nitro-modules": ">=0.36.1"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/lib/",
      "/example/"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}